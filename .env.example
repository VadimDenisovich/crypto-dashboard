# ==============================================================
#  crypto-dashboard — пример переменных окружения
#  Скопируй в `.env` (он в .gitignore) и заполни ЛОКАЛЬНО.
#  В прод-окружении значения хранятся в GitHub Secrets, не здесь.
# ==============================================================

# === LOCAL Postgres (для docker-compose.dev.yml) ===
DB_USER=user
DB_PASSWORD=postgres
DB_NAME=crypto-db

# === BACKEND ===
# Подключение к БД. На сервере подставь реальный host:port уже-поднятого postgres.
BACKEND_DATABASE_URL=postgresql+asyncpg://user:postgres@postgres:5432/crypto-db

# Подключение к Redis. На сервере — host:port уже-поднятого redis.
BACKEND_REDIS_URL=redis://redis:6379/0

# JWT-секрет: сгенерируй ЛОКАЛЬНО, в репо НЕ коммить.
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
BACKEND_JWT_SECRET=CHANGE_ME_GENERATE_LOCALLY

# Fernet-ключ для шифрования API-ключей бирж: сгенерируй ЛОКАЛЬНО.
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKEND_ENCRYPTION_KEY=CHANGE_ME_GENERATE_LOCALLY

BACKEND_ACCESS_TOKEN_TTL_MIN=15
BACKEND_REFRESH_TOKEN_TTL_DAYS=7
BACKEND_CORS_ORIGINS=http://localhost:5173
BACKEND_LOG_LEVEL=INFO

# === ENGINE ===
# Движок шарит БД и Redis с бэком. Fernet-ключ ДОЛЖЕН совпадать с BACKEND_ENCRYPTION_KEY,
# иначе движок не сможет расшифровать сохранённые бэком API-ключи бирж.
ENGINE_DATABASE_URL=postgresql+asyncpg://user:postgres@postgres:5432/crypto-db
ENGINE_REDIS_URL=redis://redis:6379/0
ENGINE_ENCRYPTION_KEY=CHANGE_ME_GENERATE_LOCALLY
ENGINE_LOG_LEVEL=INFO
ENGINE_HEARTBEAT_INTERVAL_SEC=10
ENGINE_BALANCE_POLL_INTERVAL_SEC=15
ENGINE_STATE_SNAPSHOT_TTL_SEC=30
ENGINE_COMMAND_DEDUP_TTL_SEC=86400

# === DEV: тестовые ключи бирж для seed-скриптов (не нужны прод/CI) ===
# Локально для scripts/seed_dev_credential.py — не читаются движком напрямую.
# DEV_BINANCE_TESTNET_API_KEY=
# DEV_BINANCE_TESTNET_API_SECRET=

# === FRONTEND ===
VITE_API_URL=http://localhost:8000/api/
VITE_WS_URL=ws://localhost:8000/ws/updates

# === DEPLOY (только напоминание, в .env не нужны) ===
# Эти переменные настраиваются как GitHub Secrets — см. README, секция CI/CD.
#   DEPLOY_SSH_HOST   — IP/домен сервера
#   DEPLOY_SSH_PORT   — порт SSH
#   DEPLOY_SSH_USER   — пользователь на сервере
#   DEPLOY_SSH_KEY    — приватный SSH-ключ (см. ssh-keygen -t ed25519)
#   DEPLOY_PATH       — путь до проекта на сервере (например /docker/crypto-dashboard)
